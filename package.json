{
  "private": true,
  "scripts": {
    "cli": "ts-node --files packages/cli",
    "build": "rm -rf dist && tsc",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "format": "rustfmt programs/**/src/lib.rs",
    "postinstall": "bash .anchor/build.sh"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.93.4",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "postinstall": "^0.10.3",
    "prettier": "^3.5.3",
    "rustfmt": "^0.1.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.8.2"
  }
}
